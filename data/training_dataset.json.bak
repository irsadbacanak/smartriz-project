    "cases": [
      {
        "id": "AT-11",
        "source": "AutoTRIZ casebase (pipeline operations / pigging)",
        "language": "en",
        "domain": "oil-gas/manufacturing",
        "problem": "Pipeline inspection pigs must be rigid enough to carry sensor payloads and clear wax blockages, yet flexible enough to negotiate tight bends and diameter changes without getting stuck.",
        "contradiction_pair": {
          "improving_parameter": "Adaptability/versatility (#35)",
          "worsening_parameter": "Strength (#14)"
        },
        "inventive_principles": [
          "#1 Segmentation",
          "#15 Dynamics",
          "#29 Pneumatic or hydraulic construction"
        ],
        "reasoning_chain": "1) Concrete: a rigid pig jams in bends; a flexible pig lacks the push force to clear blockages. 2) Improving: adaptability to geometry (#35). Worsening: structural strength for blockage clearing (#14). 3) Matrix (35,14) → {1, 15, 29, 40}. 4) Apply #1 Segmentation: divide pig body into rigid sensor modules linked by articulating joints. 5) Apply #15 Dynamics: joints allow each segment to independently follow pipe curvature. 6) Apply #29 Pneumatic: inflatable disc seals maintain pipeline pressure differential at each segment, preserving pushing force without relying on a single rigid body. 7) Combination retains full pushing strength while negotiating bends up to 1.5D radius.",
        "solution": "Multi-body articulated pig: rigid sensor/scraper modules connected by flexible universal-joint couplings, each sealed with inflatable polyurethane discs. The segmented design tracks tight bends while cumulative differential pressure across all seals produces ample driving force.",
        "complexity": "medium"
      },
      {
        "id": "AT-12",
        "source": "AutoTRIZ casebase (space systems engineering)",
        "language": "en",
        "domain": "aerospace",
        "problem": "Satellite solar arrays must be large enough (tens of square metres) to generate sufficient power in orbit, but must fit within the narrow cylindrical launch vehicle fairing during ascent.",
        "contradiction_pair": {
          "improving_parameter": "Use of energy by stationary object (#20)",
          "worsening_parameter": "Volume of stationary object (#8)"
        },
        "inventive_principles": [
          "#7 Nested doll",
          "#15 Dynamics",
          "#17 Transition to another dimension"
        ],
        "reasoning_chain": "1) Larger array = more power; larger array = doesn't fit in fairing. 2) Improve #20 (energy harvested), worsen #8 (stowed volume). 3) Matrix (20,8) → {7, 15, 17, 2}. 4) Apply #7 Nested doll: panels fold inside one another in a Z-fold accordion arrangement. 5) Apply #17 Transition to another dimension: roll the flexible substrate into a cylinder (ROSA concept — Roll-Out Solar Array). 6) Apply #15 Dynamics: a deployment mechanism with motorised booms unrolls the array in orbit. 7) Results: 250 W/kg specific power, <1 m³ stowed volume for 50 m² deployed area.",
        "solution": "Roll-Out Solar Array (ROSA): a flexible photovoltaic blanket wound on a drum; two motorised composite booms unroll and tension the blanket to full span after fairing separation. Used on ISS and Dragon missions.",
        "complexity": "medium"
      },
      {
        "id": "AT-13",
        "source": "AutoTRIZ casebase (coal mining safety)",
        "language": "en",
        "domain": "mining/energy",
        "problem": "Methane accumulates in underground coal mines, creating explosion risk. Forced-ventilation dilution requires enormous airflow that disrupts mining operations and is energy-intensive.",
        "contradiction_pair": {
          "improving_parameter": "Object-generated harmful factors (#31)",
          "worsening_parameter": "Productivity (#39)"
        },
        "inventive_principles": [
          "#22 Convert harm into benefit",
          "#2 Taking out",
          "#39 Inert atmosphere"
        ],
        "reasoning_chain": "1) Ventilation removes methane but displaces miners and equipment during high-flow events. 2) Improving: reducing methane hazard (#31). Worsening: mining productivity (#39). 3) Matrix (31,39) → {22, 35, 2, 28}. 4) Apply #2 Taking out: extract methane separately before mining by pre-drilling degassing boreholes into the coal seam. 5) Apply #22 Convert harm to benefit: captured methane is fed to surface gas grid or power generators. 6) Apply #39 Inert atmosphere: residual voids flushed with N₂ reduce in-seam concentration below explosive limit. 7) Outcome: mine productivity unaffected, methane hazard controlled at source.",
        "solution": "Pre-mine degassing: directional boreholes drilled into virgin coal ahead of the working face extract methane by suction. Captured gas is compressed into the national grid or burned in a mine-mouth power plant, converting a safety hazard into revenue.",
        "complexity": "medium"
      },
      {
        "id": "AT-14",
        "source": "AutoTRIZ casebase (rotary-wing aircraft icing)",
        "language": "en",
        "domain": "aerospace",
        "problem": "Ice accumulates on helicopter rotor blades in flight, adding mass and altering the aerodynamic profile; uneven ice shedding causes severe vibration. Continuous heating is impractical due to power limits.",
        "contradiction_pair": {
          "improving_parameter": "Object-affected harmful factors (#30)",
          "worsening_parameter": "Use of energy by moving object (#19)"
        },
        "inventive_principles": [
          "#22 Convert harm into benefit",
          "#37 Thermal expansion",
          "#19 Periodic action"
        ],
        "reasoning_chain": "1) Ice formation harms blade; continuous electric heat exceeds rotor power budget. 2) Improving #30 (harm reduction). Worsening #19 (energy use). 3) Matrix (30,19) → {22, 35, 2, 19}. 4) Apply #22 Convert harm to benefit: use the centrifugal force during shedding as a self-cleaning mechanism. 5) Apply #37 Thermal expansion: resistive elements bonded at the leading edge expand when pulsed, cracking the ice-alloy bond. 6) Apply #19 Periodic action: short high-power pulses (electrothermal debonding) consume far less energy than continuous heat; ice shedding by centrifugal force once bond is broken. 7) Outcome: 70% reduction in power requirement vs. continuous systems.",
        "solution": "Pulsed electrothermal de-icing: thin-film heater elements bonded beneath the leading-edge abrasion shield receive high-current pulses from slip rings, breaking the adhesive ice bond. Centrifugal force then ejects ice fragments outboard. Sequential span-wise pulsing balances ice shedding loads.",
        "complexity": "medium"
      },
      {
        "id": "AT-15",
        "source": "AutoTRIZ casebase (offshore drilling, flexible riser)",
        "language": "en",
        "domain": "oil-gas/offshore",
        "problem": "Marine drilling risers connecting a floating platform to the wellhead must withstand deep-sea pressure, fatigue from wave-induced platform motion, and high internal pressure, yet must be light and flexible enough for deployment and retrieval.",
        "contradiction_pair": {
          "improving_parameter": "Strength (#14)",
          "worsening_parameter": "Weight of moving object (#1)"
        },
        "inventive_principles": [
          "#40 Composite materials",
          "#30 Flexible shells and thin films",
          "#1 Segmentation"
        ],
        "reasoning_chain": "1) High-strength riser = thick steel = heavy, hard to bend/handle. 2) Improve #14, worsen #1. 3) Matrix (14,1) → {1, 8, 15, 40}. 4) Apply #40 Composite: CFRP structural carcass provides hoop strength at low weight. 5) Apply #30 Flexible shells: thin polymer pressure-barrier and anti-wear layers allow bending. 6) Apply #1 Segmentation: alternating armor wires wound helically in opposing angles absorb tension and compression independently. 7) Buoyancy modules attached externally reduce effective submerged weight. 8) Result: flexible composite riser with same burst rating as steel at 40% lower mass.",
        "solution": "Flexible composite riser: carbon-fibre reinforced polymer carcass + polymer pressure barrier + counter-wound helical wire armour + polyethylene outer sheath. Clip-on syntactic foam buoyancy modules offset most of the submerged weight.",
        "complexity": "complex"
      },
      {
        "id": "ALT-05",
        "source": "Altshuller, The Innovation Algorithm (ship rolling stabilizer)",
        "language": "en",
        "domain": "transportation/marine",
        "problem": "A ship must be stabilized against rolling in heavy seas, but stabilizer fins add drag that wastes fuel in calm conditions. Fixed fins that are effective in heavy weather are inefficient at all times.",
        "contradiction_pair": {
          "improving_parameter": "Object-affected harmful factors (#30)",
          "worsening_parameter": "Loss of energy (#22)"
        },
        "inventive_principles": [
          "#15 Dynamics",
          "#19 Periodic action",
          "#23 Feedback"
        ],
        "reasoning_chain": "1) Large fins damp rolling but create permanent drag. 2) Improve #30 (reduce roll harm), worsen #22 (drag = energy loss). 3) Matrix (30,22) → {15, 23, 22, 2}. 4) Apply #15 Dynamics: make fin angle actively variable, not fixed. 5) Apply #23 Feedback: gyroscope measures roll rate and angle; servo drives fin angle to generate opposing moment in real time. 6) Apply #19 Periodic action: fins feather to zero incidence in calm seas, eliminating drag. 7) Result: active fin stabilizer that is highly effective in rough seas and drag-free in calm conditions.",
        "solution": "Active retractable fin stabilizer: gyroscope and rate sensors feed a control computer that drives hydraulic actuators to set fin angle proportional to roll rate. In calm seas the fins feather (zero lift/drag) or retract inside the hull. 85–95% roll reduction in heavy seas with negligible calm-water penalty.",
        "complexity": "medium"
      },
      {
        "id": "ALT-06",
        "source": "Altshuller, Creativity as an Exact Science (oil well fire)",
        "language": "en",
        "domain": "energy/safety",
        "problem": "A burning oil well cannot be extinguished with water — water boils and disperses before reaching the seat of the fire. Foam is consumed rapidly. The fire must be snuffed instantly to prevent further damage.",
        "contradiction_pair": {
          "improving_parameter": "Object-affected harmful factors (#30)",
          "worsening_parameter": "Loss of substance (#23)"
        },
        "inventive_principles": [
          "#22 Convert harm into benefit",
          "#39 Inert atmosphere",
          "#19 Periodic action"
        ],
        "reasoning_chain": "1) Any extinguishing substance (water, foam) is destroyed by intense heat before reaching the base. 2) Improve #30 (reduce fire harm), worsen #23 (extinguishing agent lost). 3) Matrix (30,23) → {22, 39, 2, 28}. 4) Apply #22 Convert harm to benefit: use a conventional explosive. The explosion displaces the oxygen-fuel mixture faster than the flame-front can propagate. 5) Apply #39 Inert atmosphere: the detonation products (CO₂, N₂, steam) create a momentary oxygen-deficient zone at the wellhead. 6) Apply #19 Periodic: a second smaller charge removes residual flame pockets. 7) Classic Red Adair technique.",
        "solution": "Explosive well-fire extinction: a high-explosive charge detonated at the wellhead ejects the burning gas-air mixture faster than combustion can continue, creating a momentary oxygen-depleted zone. Massive water curtains then cool the wellhead to prevent re-ignition.",
        "complexity": "medium"
      },
      {
        "id": "ALT-07",
        "source": "Altshuller, And Suddenly the Inventor Appeared (periscope wake)",
        "language": "en",
        "domain": "aerospace/defense",
        "problem": "A submarine periscope creates a visible V-shaped wake when the vessel moves at speed, betraying its position to aircraft. Slowing down to reduce the wake makes the submarine unresponsive during an attack.",
        "contradiction_pair": {
          "improving_parameter": "Speed (#9)",
          "worsening_parameter": "Loss of information (#24)"
        },
        "inventive_principles": [
          "#13 Inversion",
          "#2 Taking out",
          "#28 Mechanics substitution"
        ],
        "reasoning_chain": "1) Faster speed = larger wake = visible position. 2) Improve #9 (speed), worsen #24 (position secrecy compromised). 3) Matrix (9,24) → {13, 28, 35, 2}. 4) Apply #13 Inversion: instead of a hull-penetrating periscope, invert the concept — photonic mast does not penetrate the pressure hull at all. 5) Apply #2 Taking out: optics are extracted to a non-rotating electronic imager at the mast tip. 6) Apply #28 Mechanics substitution: replace mechanical rotation with electronic pan/tilt and image stitching. 7) Mast exposure time reduces from minutes to 1–2 seconds, making wake detection nearly impossible.",
        "solution": "Non-hull-penetrating photonic/optronic mast: a slim carbon-fibre mast carries CCD/IR cameras at the tip; image data is transmitted electrically to a central display. Exposure above water lasts <2 s, eliminating any detectable wake.",
        "complexity": "medium"
      },
      {
        "id": "ALT-08",
        "source": "Altshuller, Innovation Algorithm (rotating shaft temperature)",
        "language": "en",
        "domain": "manufacturing/measurement",
        "problem": "The temperature of a rapidly spinning turbine shaft must be measured precisely during operation; attaching a thermocouple to the shaft requires sliding contacts that introduce noise and wear.",
        "contradiction_pair": {
          "improving_parameter": "Accuracy of measurement (#28)",
          "worsening_parameter": "Device complexity (#36)"
        },
        "inventive_principles": [
          "#28 Mechanics substitution",
          "#26 Copying",
          "#32 Color changes"
        ],
        "reasoning_chain": "1) Contact thermocouple on spinning shaft needs slip rings → noise, wear, complexity. 2) Improve #28 (accuracy), worsen #36 (complexity). 3) Matrix (28,36) → {26, 32, 28, 2}. 4) Apply #28 Mechanics substitution: replace electrical contact with a field-based measurement — infrared pyrometry. 5) Apply #26 Copying: use an optical replica of the radiation emitted (IR band imaging). 6) Apply #32 Color changes: coat shaft with temperature-indicating paint whose fluorescence wavelength shifts with temperature for easy optical reading. 7) Result: non-contact measurement, ±1°C accuracy, zero wear.",
        "solution": "Dual-wavelength infrared pyrometer aligned at the shaft through a sapphire window: ratio of two IR emission bands gives emissivity-independent temperature. Phosphorescent temperature-sensitive paint applied to shaft provides visual confirmation during initial calibration.",
        "complexity": "simple"
      },
      {
        "id": "ALT-09",
        "source": "Altshuller, ARIZ applied examples (railway switch icing)",
        "language": "en",
        "domain": "transportation/civil",
        "problem": "Railway track switches accumulate ice and compacted snow in winter, causing switches to jam and trains to be delayed or derailed. Manual clearing is slow and labour-intensive.",
        "contradiction_pair": {
          "improving_parameter": "Reliability (#27)",
          "worsening_parameter": "Loss of energy (#22)"
        },
        "inventive_principles": [
          "#22 Convert harm into benefit",
          "#37 Thermal expansion",
          "#35 Parameter changes"
        ],
        "reasoning_chain": "1) Heating rails to prevent ice uses energy; unheated rails jam. 2) Improve #27 (reliability), worsen #22 (energy). 3) Matrix (27,22) → {22, 35, 3, 37}. 4) Apply #22 Convert harm: ice itself can be used as a trigger — moisture sensors detect ice-forming conditions. 5) Apply #37 Thermal expansion: resistance heating wire embedded in the switch rail groove expands and cracks ice adhesion. 6) Apply #35 Parameter change: apply heating only in the transition zone where ice matters, not the whole track. 7) Smart thermostat activates only when ambient temperature and humidity form ice — typical 70% energy saving vs. always-on systems.",
        "solution": "Embedded electric switch-heating: stainless-steel resistance wires cast into the rail groove, controlled by a microprocessor that monitors rail temperature and atmospheric moisture. Activates only when ice-forming conditions are met; consumes <3 kW per switch; eliminates 98% of ice-related switch failures.",
        "complexity": "simple"
      },
      {
        "id": "ALT-10",
        "source": "Altshuller, ARIZ (glass tubing drawing)",
        "language": "en",
        "domain": "manufacturing/materials",
        "problem": "Drawing very thin borosilicate glass tubes at high speed produces uneven wall thickness because thermal gradients around the mandrel cause asymmetric viscosity distribution in the molten glass.",
        "contradiction_pair": {
          "improving_parameter": "Productivity (#39)",
          "worsening_parameter": "Manufacturing precision (#29)"
        },
        "inventive_principles": [
          "#19 Periodic action",
          "#35 Parameter changes",
          "#3 Local quality"
        ],
        "reasoning_chain": "1) Faster drawing → larger thermal asymmetry → wall thickness variation. 2) Improve #39, worsen #29. 3) Matrix (39,29) → {19, 35, 10, 3}. 4) Apply #19 Periodic: rotate the mandrel and blank continuously during drawing — thermal gradients are averaged around the circumference. 5) Apply #35 Parameter change: control mandrel temperature independently from blank draw temperature. 6) Apply #3 Local quality: apply local infra-red lamps to cold side only. 7) Rotation averaging eliminates asymmetry; speed can increase without precision loss.",
        "solution": "Rotating-mandrel Danner process: the mandrel rotates at 10–30 rpm while molten glass spirals around it and is drawn downward. Circumferential averaging of any thermal asymmetry ensures uniform wall thickness at draw speeds 30% higher than static-mandrel processes.",
        "complexity": "medium"
      },
      {
        "id": "ALT-11",
        "source": "Altshuller, And Suddenly the Inventor Appeared (steel cable inspection)",
        "language": "en",
        "domain": "mining/civil",
        "problem": "Steel wire ropes in mine hoists fatigue internally and break without warning; visual inspection only detects surface breaks and requires stopping the hoist, disrupting production.",
        "contradiction_pair": {
          "improving_parameter": "Reliability (#27)",
          "worsening_parameter": "Loss of time (#25)"
        },
        "inventive_principles": [
          "#28 Mechanics substitution",
          "#26 Copying",
          "#10 Preliminary action"
        ],
        "reasoning_chain": "1) Safe rope requires frequent inspection; inspection halts production (time loss). 2) Improve #27, worsen #25. 3) Matrix (27,25) → {28, 10, 3, 35}. 4) Apply #28 Mechanics substitution: replace visual/tactile inspection with a magnetic field. 5) Apply #26 Copying: wrap a magnetic-flux-leakage (MFL) sensor collar around the rope; flaws cause detectable anomalies in the leakage field — a non-contact 'copy' of internal defects. 6) Apply #10 Preliminary action: magnetise a rope segment before it enters the sensor collar. 7) MFL head travels with the rope at full operating speed; output streamed to surface for AI-based defect classification without any production stop.",
        "solution": "Continuous magnetic-flux-leakage rope tester: permanent-magnet yokes saturate a rope segment; Hall-effect sensors read the flux leakage signature of every wire break, corrosion pit, and cross-section loss. Full-speed, in-service testing yields daily rope condition reports without halting the hoist.",
        "complexity": "medium"
      },
      {
        "id": "ALT-12",
        "source": "Altshuller, Creativity as an Exact Science (blast-furnace taphole)",
        "language": "en",
        "domain": "manufacturing/metallurgy",
        "problem": "The taphole of a blast furnace must be sealed with refractory clay after tapping. When re-tapping, the hardened clay plug must be drilled out quickly; slow drilling wastes heat and delays production.",
        "contradiction_pair": {
          "improving_parameter": "Ease of operation (#33)",
          "worsening_parameter": "Object-affected harmful factors (#30)"
        },
        "inventive_principles": [
          "#10 Preliminary action",
          "#13 Inversion",
          "#35 Parameter changes"
        ],
        "reasoning_chain": "1) Hard clay stops drilling progress; faster drilling risks oxygen lance blow-through near molten iron. 2) Improve #33 (ease of opening), worsen #30 (risk of splashback). 3) Matrix (33,30) → {10, 35, 21, 28}. 4) Apply #10 Preliminary action: cast the plug material around a pre-inserted graphite rod that burns away under oxygen, creating an initial bore. 5) Apply #13 Inversion: instead of drilling in, burn through with an oxygen lance from outside — material is removed from the taphole side toward the furnace interior. 6) Apply #35 Parameter change: use a pre-conditioned low-density clay on the inner face that opens easily, with harder clay only on the outer face. 7) Opening time reduces from 8 min to 90 s.",
        "solution": "Combination taphole system: the inner half of the clay plug is a fast-burning low-density compound; the outer half is dense refractory for sealing. A water-cooled oxygen lance burns through the inner material in <90 s; drill is used only if lance fails.",
        "complexity": "medium"
      },
      {
        "id": "ALT-13",
        "source": "Altshuller, Innovation Algorithm (TBM cutter replacement)",
        "language": "en",
        "domain": "civil/mining",
        "problem": "Tunnel-boring machine disc cutters wear rapidly in hard rock; replacing them requires workers to enter the dangerous cutterhead excavation face under compressed air, causing health risks and long downtime.",
        "contradiction_pair": {
          "improving_parameter": "Reliability (#27)",
          "worsening_parameter": "Ease of repair (#34)"
        },
        "inventive_principles": [
          "#27 Cheap short-living objects",
          "#25 Self-service",
          "#1 Segmentation"
        ],
        "reasoning_chain": "1) Hard rock demands frequent cutter change; each change = entry into hazardous compressed-air environment. 2) Improve #27, worsen #34. 3) Matrix (27,34) → {1, 27, 35, 3}. 4) Apply #1 Segmentation: design modular rear-loading cutter housings accessible from the safe pressurized crew chamber behind the bulkhead. 5) Apply #27 Cheap short-living objects: make disc rings (the wear element) separately replaceable without removing the entire cutter assembly. 6) Apply #25 Self-service: embed wear-indicator pins that shear at minimum thickness, pushing a signal pin visible through an inspection port. 7) Cutter change at full pressure in crew compartment with no face exposure.",
        "solution": "Rear-loading cutter system: disc rings slide axially out of their housings through sealed ports in the TBM bulkhead, serviced from the safe crew compartment. Colour-coded wear-indicator pins provide visual go/no-go status. Average change time cut from 4 h to 45 min.",
        "complexity": "complex"
      },
      {
        "id": "ALT-14",
        "source": "Altshuller, Innovation Algorithm (flexible deep-sea pipeline)",
        "language": "en",
        "domain": "oil-gas/marine",
        "problem": "A deep-sea pipeline connecting wellhead to floating production vessel must withstand thousands of fatigue cycles from platform motion and 200-bar external pressure, yet must remain flexible enough to accommodate large catenary displacements.",
