{
  "dataset_name": "SmarTRIZ-Seed-v1",
  "version": "2026-05-05",
  "schema": {
    "id": "string",
    "source": "string",
    "language": "en|tr|mixed",
    "domain": "string",
    "problem": "string",
    "contradiction_pair": {
      "improving_parameter": "name (#)",
      "worsening_parameter": "name (#)"
    },
    "inventive_principles": ["#name", "..."],
    "reasoning_chain": "string",
    "solution": "string",
    "complexity": "simple|medium|complex"
  },
  "cases": [

    {
      "id": "AT-01",
      "source": "AutoTRIZ casebase (Orloff 2012, Modern TRIZ p.187)",
      "language": "en",
      "domain": "civil/environmental",
      "problem": "To prevent water erosion of river banks, they can be strengthened with stones. However, water gradually washes sand and soil from under the stones, and the shoreline collapses. What can we do?", 
      "contradiction_pair": {
        "improving_parameter": "Stability of object's composition (#13)",
        "worsening_parameter": "Loss of substance (#23)"
      },
      "inventive_principles": ["#24 Intermediary/Mediator", "#40 Composite materials"],
      "reasoning_chain": "1) Specific problem: stones protect bank but underlying soil is still washed away. 2) Generalize: improve stability of bank composition without losing substance under stones. 3) Map to 39 parameters: improving = #13 stability of composition; worsening = #23 loss of substance. 4) Matrix lookup at (13,23): principles include #24, #2, #35, #40. 5) Apply #24 Mediator: insert an intermediate object between stones and water that holds the stones together while letting water pass. 6) Concrete: durable wire mesh that fixes stones in place. 7) Refine: prefabricated wire-mesh baskets (gabions) give the construction the required size and shape and remain permeable.",
      "solution": "The stones are fixed with durable mesh wire. Stones are placed inside prefabricated gabion sections (mesh wire baskets), giving the bank construction the required shape and size while preventing the under-soil from being washed out.", 
      "complexity": "simple"
    },

    {
      "id": "AT-02",
      "source": "AutoTRIZ casebase (Childs 2013, Mechanical Design Engineering Handbook p.136)",
      "language": "en",
      "domain": "manufacturing/consumer-products",
      "problem": "An axe must be light enough for the user to swing repeatedly without fatigue, yet must deliver a powerful blow. Reducing handle mass usually reduces blow energy because mass at the head is what matters.",
      "contradiction_pair": {
        "improving_parameter": "Weight of moving object (#1)",
        "worsening_parameter": "Force/Intensity (#10)"
      },
      "inventive_principles": ["#29 Pneumatic or hydraulic construction", "#1 Segmentation"],
      "reasoning_chain": "1) Concrete problem: heavy axe is tiring; light axe is weak. 2) Identify contradiction: lower weight (#1) usually lowers force at impact (#10). 3) Look up matrix (1,10): principles 8, 10, 18, 37 → also commonly 29 in modern matrix. 4) Apply #29: replace solid handle interior with air. 5) Hollow handle shifts the centre of gravity forward, concentrating mass at the head while overall weight drops. 6) Result: a lighter tool that delivers a more powerful blow because of mass distribution.",
      "solution": "Fiskars axe with a hollow handle: by replacing solid plastic with air inside the handle, the centre of gravity is moved toward the head; the axe is lighter overall but delivers a more powerful blow.", 
      "complexity": "simple"
    },

    {
      "id": "AT-03",
      "source": "AutoTRIZ casebase (textbook diving case)",
      "language": "en",
      "domain": "sports/biomedical",
      "problem": "In competitive high diving, divers must repeatedly practise dives, but each impact between diver and water can cause injury. Lowering impact by reducing height makes practice unrealistic.",
      "contradiction_pair": {
        "improving_parameter": "Object-affected harmful factors (#30)",
        "worsening_parameter": "Productivity (#39)"
      },
      "inventive_principles": ["#11 Cushion in advance/Beforehand cushioning", "#35 Transformation of properties", "#37 Thermal expansion", "#28 Mechanical substitution"], 
      "reasoning_chain": "1) Problem: high impacts injure divers but practice volume must remain high. 2) Translate to TRIZ: reduce harm acting on diver (#30) without reducing practice productivity (#39). 3) Matrix (30,39) suggests cushioning-type principles. 4) Apply #11 Cushion in advance: prepare the water to be 'softer' before impact. 5) Apply #35 Transform state: change state/properties of water (introduce gas). 6) Concrete mechanism: bubble curtain that aerates the landing zone. 7) Aerated water absorbs impact energy via compressible air bubbles, reducing surface tension and peak deceleration on the diver.",
      "solution": "Aerate the pool surface with a bubble curtain during practice. The aerated water layer is compressible and 'softer', dramatically reducing impact loads on the diver and enabling many more practice dives without injury.", 
      "complexity": "simple"
    },

    {
      "id": "AT-04",
      "source": "AutoTRIZ casebase / Savransky 2000 p.229",
      "language": "en",
      "domain": "manufacturing/materials",
      "problem": "A pneumatic conveying system originally built (with plastic piping) to transport plastic pellets must now transport metal shots. The shots wear out the plastic elbows quickly, causing failures.", 
      "contradiction_pair": {
        "improving_parameter": "Speed (#9)",
        "worsening_parameter": "Stability of object's composition (#13)"
      },
      "inventive_principles": ["#28 Mechanical substitution"],
      "reasoning_chain": "1) Concrete: high-speed metal shots impact plastic elbows, eroding them. 2) Improving: throughput speed (#9). Worsening: stability of plastic composition (#13). 3) Matrix (9,13) → {28, 33, 1, 18}. 4) Pick #28 Mechanical substitution: replace mechanical (kinetic-impact) interaction with a field-based one. 5) Use a magnetic field at the elbow to attract some metal shots and pin them to the wall. 6) The pinned shots form a self-renewing 'blanket' of metal that absorbs the impact instead of the plastic. 7) The plastic elbow is no longer in contact with high-speed metal — wear stops.",
      "solution": "Place a permanent magnet at each elbow. Some metal shots adhere to the inside of the elbow under the magnetic field, forming an energy-absorbing layer of shots. Subsequent shots impact this self-replenishing metallic layer rather than the plastic, eliminating elbow wear.", 
      "complexity": "medium"
    },

    {
      "id": "AT-05",
      "source": "AutoTRIZ casebase (Altshuller, Innovation Algorithm)",
      "language": "en",
      "domain": "aerospace",
      "problem": "An anti-tank gun fires a round whose shielding must be thick enough to survive launch acceleration and engagement, but thin enough not to add prohibitive mass that reduces range and projectile speed.",
      "contradiction_pair": {
        "improving_parameter": "Strength (#14)",
        "worsening_parameter": "Weight of moving object (#1)"
      },
      "inventive_principles": ["#40 Composite materials", "#1 Segmentation", "#3 Local quality"],
      "reasoning_chain": "1) Stronger shielding via thicker steel raises mass, lowering range (worsens #1). 2) Improve #14, worsen #1. 3) Matrix (14,1) recommends #1 Segmentation, #8 Anti-weight, #15 Dynamics, #40 Composite. 4) Apply #40 Composite: use a composite of light alloy with a hard ceramic/metal facing — high local hardness/strength at low average mass. 5) Apply #3 Local quality: stronger only at the most-stressed regions of the shield. 6) Outcome: a tailored composite shield with regional reinforcement gives required ballistic strength at lower mass.",
      "solution": "Layered composite shielding: a hard ceramic outer face bonded to a tough light-alloy backing, with local thickness increased only at high-stress regions. The composite provides the required ballistic resistance while keeping mass within range/speed limits.",
      "complexity": "medium"
    },

    {
      "id": "AT-06",
      "source": "AutoTRIZ casebase (Fey & Rivin, Innovation on Demand)",
      "language": "en",
      "domain": "energy",
      "problem": "High-voltage transmission lines accumulate ice in winter, increasing weight and breaking towers. Mechanical de-icing is dangerous and slow.",
      "contradiction_pair": {
        "improving_parameter": "Object-affected harmful factors (#30)",
        "worsening_parameter": "Loss of energy (#22)"
      },
      "inventive_principles": ["#22 Convert harm into benefit", "#19 Periodic action", "#37 Thermal expansion"],
      "reasoning_chain": "1) Ice buildup is harmful; removing it usually wastes energy. 2) Improving #30 (reduce harm), worsening #22 (extra energy needed). 3) Apply #22 Convert harm to benefit: use the existing electric current itself. 4) Periodically short the line through a controlled load to drive a higher current; resistive heating melts ice. 5) Apply #19 Periodic action so heating is pulsed and minimally disruptive. 6) Energy 'lost' as I²R heat is no longer lost — it serves the de-icing function.",
      "solution": "Use a controlled short-circuit/high-current pulse on each phase to drive resistive heating that melts accumulated ice. Periodic, automated pulses keep lines clear without mechanical access.",
      "complexity": "medium"
    },

    {
      "id": "AT-07",
      "source": "AutoTRIZ casebase (Orloff, Inventive Thinking through TRIZ)",
      "language": "en",
      "domain": "transportation/aerospace",
      "problem": "Icebreakers must crush thick polar ice to clear shipping lanes, but thicker hulls and bigger engines add mass and fuel cost.",
      "contradiction_pair": {
        "improving_parameter": "Strength (#14)",
        "worsening_parameter": "Weight of moving object (#1)"
      },
      "inventive_principles": ["#22 Convert harm into benefit", "#35 Parameter changes (state)", "#13 Inversion"],
      "reasoning_chain": "1) Improving icebreaker capability requires either heavier hull or stronger engine. 2) Apply #22 Convert harm to benefit: use ice itself. 3) Apply #13 Inversion: instead of crushing ice from above, lift the ice and break it from below using buoyancy/asymmetry. 4) Combine with #35: locally raise ice temperature with hull-heating to weaken bonds before mechanical loading. 5) Outcome: heated, asymmetric prow that rides up onto ice and breaks it under the ship's own weight, exploiting ice's brittle response.",
      "solution": "Heated, asymmetric icebreaker prow design: ship rides up onto ice and uses its own weight to fracture pre-weakened (heated) ice, drastically reducing required engine power and hull mass for given ice thickness.",
      "complexity": "medium"
    },

    {
      "id": "AT-08",
      "source": "AutoTRIZ casebase (Altshuller, ampoule problem)",
      "language": "en",
      "domain": "manufacturing/biomedical",
      "problem": "Glass ampoules containing pharmaceutical solution must be sealed at the open end without overheating the contents. Direct flame cracks the glass and degrades the drug.",
      "contradiction_pair": {
        "improving_parameter": "Productivity (#39)",
        "worsening_parameter": "Object-affected harmful factors (#31)"
      },
      "inventive_principles": ["#35 Parameter changes (state)", "#39 Inert atmosphere", "#11 Cushion in advance"],
      "reasoning_chain": "1) Sealing requires high local heat; drug is heat-sensitive. 2) Improve sealing throughput, worsen damage to contents. 3) Apply #35 transform state: immerse ampoules in a cool liquid bath up to the neck. 4) Apply heat only above the liquid line — the solution stays cool while the glass neck reaches sealing temperature. 5) Liquid acts as instantaneous heat sink (cushion in advance, #11). 6) High throughput sealing without thermal damage.",
      "solution": "Pass ampoules through a cool liquid bath that submerges everything but the neck, then apply a flame to the exposed neck. The bath protects the drug; only the glass neck heats and seals.",
      "complexity": "medium"
    },

    {
      "id": "AT-09",
      "source": "AutoTRIZ casebase (Silverstein, How to Achieve Competitive Excellence)",
      "language": "en",
      "domain": "manufacturing",
      "problem": "Paint must be vigorously mixed in a sealed can to produce uniform color, but inserting a mechanical agitator creates a sealing problem and contamination risk.",
      "contradiction_pair": {
        "improving_parameter": "Manufacturability (#32)",
        "worsening_parameter": "Object-generated harmful factors (#31)"
      },
      "inventive_principles": ["#28 Mechanical substitution", "#18 Mechanical vibration", "#13 Inversion"],
      "reasoning_chain": "1) Need agitation inside sealed container; agitator shaft would breach seal. 2) Apply #13 Inversion: don't put a mixer inside — move the can. 3) Apply #18 Mechanical vibration: shake/centrifuge the entire sealed can. 4) Apply #28 substitution: replace internal mechanical agitation with external orbital motion. 5) Result: no shaft, no seals, no contamination.",
      "solution": "Commercial paint shakers/centrifugal mixers grip the sealed can externally and oscillate or spin it; the contents mix vigorously through induced fluid motion without ever opening the can.",
      "complexity": "simple"
    },

    {
      "id": "AT-10",
      "source": "AutoTRIZ casebase (aerospace/space-suit case)",
      "language": "en",
      "domain": "aerospace",
      "problem": "Astronaut space suits must support oxygen consumption during EVA, but larger oxygen tanks add mass and reduce mobility.",
      "contradiction_pair": {
        "improving_parameter": "Duration of action of moving object (#15)",
        "worsening_parameter": "Weight of moving object (#1)"
      },
      "inventive_principles": ["#10 Preliminary action", "#34 Discarding/recovering", "#25 Self-service"],
      "reasoning_chain": "1) Longer EVA = more oxygen = heavier suit. 2) Apply #34 Discarding/recovering: scrub and recycle CO₂ to recover oxygen. 3) Apply #25 Self-service: integrate the recovery into the suit so astronaut effort drives part of the cycle (breathing). 4) Preliminary action (#10): pre-charge LiOH/regenerable scrubbers before EVA. 5) Outcome: closed-loop life-support extends EVA duration without adding tank mass.",
      "solution": "Closed-loop suit life support: lithium-hydroxide CO₂ scrubbers plus regenerable oxygen recovery extend EVA duration without proportional increase in stored-oxygen mass.",
      "complexity": "medium"
    },

    {
      "id": "TG-01",
      "source": "TRIZ-GPT case study (Xie & Liu 2023, Machines 11(9):912)",
      "language": "en",
      "domain": "robotics",
      "problem": "An in-pipe peristaltic robot must traverse pipes of varying diameter. The classical design uses three motors and rigid legs, leading to excess weight, control complexity, and poor adaptability when diameter changes.", 
      "contradiction_pair": {
        "improving_parameter": "Adaptability/versatility (#35)",
        "worsening_parameter": "Device complexity (#36)"
      },
      "inventive_principles": ["#1 Segmentation", "#11 Beforehand cushioning"], 
      "reasoning_chain": "1) Concrete problem: too many motors, rigid legs cannot accommodate diameter change. 2) Improving: adaptability across diameters (#35). Worsening: device complexity (#36). 3) Matrix (35,36) suggests {1, 13, 16, 15, 29}. 4) Apply #1 Segmentation: split each driven leg into rigid + flexible segments so the flexible portion conforms to local diameter. 5) Apply #11 Beforehand cushioning: pre-compressed spring on each leg ensures continuous contact with the pipe wall as diameter varies. 6) Combination eliminates need for active control of leg length while preserving traction. 7) Result: fewer motors, broader pipe-diameter range, simpler control.",
      "solution": "Each driven leg is split into a rigid section and a flexible rubber pad (segmentation), with a pre-compressed spring (beforehand cushioning) maintaining contact pressure. The robot adapts to a wide range of pipe diameters with fewer motors and simpler control.",
      "complexity": "medium"
    },

    {
      "id": "TG-02",
      "source": "TRIZ-GPT case base (Chang et al. 2023, Adv. Eng. Inf. 56:101901)",
      "language": "en",
      "domain": "biomedical/product-design",
      "problem": "A blood-collection test tube rack used in clinical labs must hold tubes of various sizes, be safe to handle, easy to manufacture, and easy to clean.",
      "contradiction_pair": {
        "improving_parameter": "Adaptability/versatility (#35)",
        "worsening_parameter": "Device complexity (#36)"
      },
      "inventive_principles": ["#15 Dynamization", "#1 Segmentation", "#35 Parameter changes"],
      "reasoning_chain": "1) Tubes vary in diameter and length; rigid rack accommodates only one type. 2) Improve adaptability (#35) without adding complexity (#36). 3) Apply #15 Dynamization: slot geometry adapts (retractable/expandable inserts). 4) Apply #1 Segmentation: rack and lid are detachable for cleaning. 5) Apply #35 (shape change): rounded body, no sharp edges. 6) Tubes can rotate in slots for flexible handling. 7) Final design integrates all three.",
      "solution": "Round-shape, demountable test-tube rack with adaptive slots that grip different tube diameters via expandable inserts. Rounded body improves safety; demountable cover simplifies manufacture and cleaning.", 
      "complexity": "medium"
    },

    {
      "id": "TG-03",
      "source": "TRIZ-GPT collection (Gilani & Lee 2023, TRIZ Future Conf.)",
      "language": "en",
      "domain": "electronics/HCI",
      "problem": "An online museum virtual exhibition should be highly interactive and immersive, but added features make the interface harder to operate for casual visitors.",
      "contradiction_pair": {
        "improving_parameter": "Ease of operation (#33)",
        "worsening_parameter": "Device complexity (#36)"
      },
      "inventive_principles": ["#2 Taking out", "#15 Dynamization", "#25 Self-service"],
      "reasoning_chain": "1) Adding features increases complexity, hurts usability. 2) Apply #2 Taking out: hide advanced controls behind progressive-disclosure menus. 3) Apply #15 Dynamization: UI adapts to user expertise (novice vs. curator). 4) Apply #25 Self-service: tutorial overlays help users teach themselves. 5) Outcome: simple default UI, with depth on demand.",
      "solution": "Adaptive UI with progressive disclosure: novice users see a minimal, guided interface; advanced users unlock immersive controls. Self-service tutorials reduce support burden.",
      "complexity": "simple"
    },

    {
      "id": "TG-04",
      "source": "TRIZ-GPT few-shot example (muscle-powered submarine)",
      "language": "en",
      "domain": "transportation",
      "problem": "Existing muscle-powered submarines require huge effort for sustained high speed; conventional propellers are inefficient and cause water resistance.",
      "contradiction_pair": {
        "improving_parameter": "Productivity (#39)",
        "worsening_parameter": "Ease of operation (#33)"
      },
      "inventive_principles": ["#28 Mechanics substitution"],
      "reasoning_chain": "1) Propeller mechanics are inefficient; making them more efficient via gearing increases operator load. 2) Apply #28: replace mechanical propulsion with hydrodynamic. 3) Use Coandă-effect water flow drawn in by a muscle pump and ejected along the hull. 4) Front jets reduce resistance, rear jets propel. 5) Operator effort goes into a pump rather than spinning a propeller, improving energy efficiency.",
      "solution": "Hydrodynamic-jet muscle-powered submarine: rider drives a pump that draws water in and ejects it through bow side-jets (Coandă-effect drag reduction) and stern jets (propulsion).",
      "complexity": "medium"
    },

    {
      "id": "TG-05",
      "source": "TRIZ-GPT few-shot example (silent desktop fan)",
      "language": "en",
      "domain": "consumer-electronics",
      "problem": "Conventional desktop fans with large rubber-coated blades are noisy, cause injury risk, and produce uneven gusts.", 
      "contradiction_pair": {
        "improving_parameter": "Object-generated harmful factors (#31)",
        "worsening_parameter": "Productivity (#39)"
      },
      "inventive_principles": ["#28 Mechanics substitution", "#19 Periodic action"],
      "reasoning_chain": "1) Bigger blades = more flow but more noise/risk. 2) Apply #28: replace bladed propulsion with bladeless air multiplication (Dyson-style induced flow). 3) Apply #19: oscillating jet creates more pleasant airflow pattern. 4) Result: equal cooling, far lower noise, no exposed blades.",
      "solution": "Bladeless desktop fan: a small impeller in the base accelerates air through an annular slit; entrained ambient air multiplies flow. No exposed blades, lower noise, smoother airflow.",
      "complexity": "simple"
    },

    {
      "id": "AT-BTMS-01",
      "source": "AutoTRIZ Adv. Eng. Informatics 2025 (BTMS case)",
      "language": "en",
      "domain": "automotive/energy",
      "problem": "An electric-vehicle battery pack must be cooled effectively across a wide ambient range, while preserving energy density, packaging volume, and weight. Liquid cooling adds mass and complexity; air cooling is uneven; phase-change materials add bulk.",
      "contradiction_pair": {
        "improving_parameter": "Shape (#12)",
        "worsening_parameter": "Loss of energy (#22)"
      },
      "inventive_principles": ["#1 Segmentation", "#17 Transition to a new dimension", "#35 Parameter changes", "#40 Composite materials"],
      "reasoning_chain": "1) Concrete: heat dissipation must be uniform across many cells without sacrificing pack density. 2) Improving: pack shape/geometry (#12). Worsening: parasitic energy loss to coolant pumping or thermal mass (#22). 3) Multiple contradictions identified by AutoTRIZ; dominant pair is (12,22). 4) Matrix → {1, 17, 35, 28, 40}. 5) Apply #1 Segmentation: subdivide cooling into per-module zones. 6) Apply #17 New dimension: extend heat-pipe contact from 1-D (single line) to 2-D (flat heat pipe with interconnected chambers wrapping cells). 7) Apply #35: phase-change working fluid inside heat pipes shifts state to absorb heat. 8) Apply #40 Composite: grooved aluminum + phase-change-fluid composite plate. 9) Result: a flat-heat-pipe-based BTMS (FHP-BTMS) that improves grouping efficiency 26%, volumetric energy density 24%, thermal management efficiency 64% vs. baseline.", 
      "solution": "Flat-Heat-Pipe BTMS: interconnected-chamber flat heat pipes with grooved structures wrap each cell, transferring heat in two dimensions; phase-change working fluid passively transports heat to a small radiator.  Reported gains: grouping efficiency +26%, volumetric energy density +24%, thermal management +64%.", 
      "complexity": "complex"
    },

    {
      "id": "ALT-01",
      "source": "Altshuller, And Suddenly the Inventor Appeared (lightning-rod problem)",
      "language": "en",
      "domain": "civil/electrical",
      "problem": "A tall radio antenna must be protected from lightning. A traditional metal lightning rod alongside the antenna interferes with the radio signal.",
      "contradiction_pair": {
        "improving_parameter": "Object-affected harmful factors (#30)",
        "worsening_parameter": "Loss of information (#24)"
      },
      "inventive_principles": ["#6 Universality", "#13 Inversion", "#19 Periodic action"],
      "reasoning_chain": "1) Lightning rod protects but blocks signal. 2) Apply #6 Universality: make the antenna itself act as the lightning rod. 3) Add a bypass circuit (#19 periodic) that grounds the antenna only during a lightning event detected by a fast field sensor. 4) Antenna performs both functions; no separate rod needed.",
      "solution": "Use the antenna as its own lightning rod with a fast switching ground that activates only during detected lightning, preserving signal during normal operation.",
      "complexity": "medium"
    },

    {
      "id": "ALT-02",
      "source": "Altshuller, Innovation Algorithm (chocolate packaging)",
      "language": "en",
      "domain": "manufacturing/packaging",
      "problem": "Chocolate must be enrobed in liquid form, then cooled to solid; molds add cost, slow throughput, and must be cleaned.",
      "contradiction_pair": {
        "improving_parameter": "Productivity (#39)",
        "worsening_parameter": "Manufacturability (#32)"
      },
      "inventive_principles": ["#35 Parameter changes", "#10 Preliminary action", "#5 Merging"],
      "reasoning_chain": "1) Molding step is bottleneck. 2) Apply #35: change state — let the chocolate solidify around its own filling on a moving belt. 3) Apply #10 Preliminary action: pre-extrude shell shape. 4) Eliminate molds entirely.",
      "solution": "Mold-less chocolate enrobing: pre-shaped fillings travel under a chocolate curtain, are cooled in line, packaged downstream. Productivity rises, cleaning costs drop. (TRIZ-derived patent used by Mars.)", 
      "complexity": "simple"
    },

    {
      "id": "ALT-03",
      "source": "Altshuller, Creativity as an Exact Science (foundry sand)",
      "language": "en",
      "domain": "manufacturing",
      "problem": "Foundry sand mold must be strong during pouring, but easy to break apart afterward to remove the casting.",
      "contradiction_pair": {
        "improving_parameter": "Strength (#14)",
        "worsening_parameter": "Ease of repair (#34)"
      },
      "inventive_principles": ["#35 Parameter changes (state)", "#36 Phase transitions", "#15 Dynamization"],
      "reasoning_chain": "1) Need strong-when-hot, weak-when-cold sand. 2) Apply #35/#36: a binder that depolymerizes above a threshold or below a threshold (e.g., CO₂-cured silicate that releases on water). 3) Mold is rigid during casting; collapses on rinse.",
      "solution": "Water-soluble silicate binder: rigid during pour, dissolves on water rinse for easy casting removal.",
      "complexity": "medium"
    },

    {
      "id": "ALT-04",
      "source": "Altshuller (split-engine compressor)",
      "language": "en",
      "domain": "energy",
      "problem": "Industrial compressor needs both high pressure and high flow rate; a single stage cannot deliver both efficiently.",
      "contradiction_pair": {
        "improving_parameter": "Pressure (#11)",
        "worsening_parameter": "Volume of moving object (#7)"
      },
      "inventive_principles": ["#1 Segmentation", "#3 Local quality", "#19 Periodic action"],
      "reasoning_chain": "1) High pressure needs small volume; high flow needs large volume. 2) Apply #1 Segmentation: split into stages. 3) Apply #3 Local quality: each stage tuned to its own pressure ratio.",
      "solution": "Multi-stage axial-then-centrifugal compressor where each stage is locally optimized; intercoolers between stages reduce work.",
      "complexity": "simple"
    },

    {
      "id": "MOD-01",
      "source": "Cortes Robles et al. 2009, Chem. Eng. Process. (chemical reactor)",
      "language": "en",
      "domain": "chemical",
      "problem": "Exothermic batch reactor needs higher productivity but hot-spots and runaway risk grow with throughput.",
      "contradiction_pair": {
        "improving_parameter": "Productivity (#39)",
        "worsening_parameter": "Object-generated harmful factors (#31)"
      },
      "inventive_principles": ["#1 Segmentation", "#19 Periodic action", "#35 Parameter changes"],
      "reasoning_chain": "1) Continuous feed in batch reactor causes runaway. 2) #1 segment reactor into microchannels — large surface-to-volume. 3) #19 pulsed feed avoids accumulation. 4) Productivity up, hot-spots eliminated.",
      "solution": "Switch to continuous-flow microreactor with pulsed reagent injection; high productivity, intrinsically safe thermals.",
      "complexity": "medium"
    },

    {
      "id": "MOD-02",
      "source": "Yao et al. 2022, Sustainability 14(22):15482 (folding-chair assembly)",
      "language": "en",
      "domain": "manufacturing",
      "problem": "A folding chair must be quick to assemble at the factory but stable and durable in use.",
      "contradiction_pair": {
        "improving_parameter": "Manufacturability (#32)",
        "worsening_parameter": "Reliability (#27)"
      },
      "inventive_principles": ["#1 Segmentation", "#5 Merging", "#10 Preliminary action"],
      "reasoning_chain": "1) Faster assembly means fewer/looser fasteners → lower reliability. 2) #5 Merging: combine multiple parts into a single hinge module. 3) #10: pre-assemble subassemblies. 4) Snap-fit + lockable hinge.",
      "solution": "Pre-assembled hinge modules with snap-fit final assembly: reduces assembly steps from 14 to 4, with no loss of stability or rated load.",
      "complexity": "simple"
    },

    {
      "id": "MOD-03",
      "source": "Deng, Feng & Wang 2010 IEEE ICIEEM (submersible motor pump)",
      "language": "en",
      "domain": "energy/manufacturing",
      "problem": "Submersible pump motor must be reliable underwater (sealed) yet serviceable when failures occur.",
      "contradiction_pair": {
        "improving_parameter": "Reliability (#27)",
        "worsening_parameter": "Ease of repair (#34)"
      },
      "inventive_principles": ["#1 Segmentation", "#26 Copying", "#27 Cheap short-living objects"],
      "reasoning_chain": "1) Hermetic seals improve reliability but mean disposing of the unit on failure. 2) #1 segmentation: modularize seals so a single module can be swapped. 3) #27 cheap-short-living: make wear parts (lip seals) inexpensive and replaceable.",
      "solution": "Modular cartridge seal with low-cost replaceable lip seals; the rest of the motor remains sealed and reliable.",
      "complexity": "medium"
    },

    {
      "id": "MOD-04",
      "source": "Akay, Demıray, Kurt 2008 IJPR (assembly ergonomics)",
      "language": "en",
      "domain": "ergonomics/manufacturing",
      "problem": "Manual assembly worker must reach far for components, causing musculoskeletal stress; redesigning the line is costly.",
      "contradiction_pair": {
        "improving_parameter": "Object-affected harmful factors (#30)",
        "worsening_parameter": "Manufacturability (#32)"
      },
      "inventive_principles": ["#10 Preliminary action", "#15 Dynamization", "#25 Self-service"],
      "reasoning_chain": "1) Reaching causes injury, but moving stations is expensive. 2) #10: pre-position parts at point of use. 3) #15: rotating part-presentation tray that brings parts within reach. 4) #25: gravity-fed self-replenishing bins.",
      "solution": "Karakuri-style gravity-fed rotating part presenters at each workstation: parts arrive within 30 cm of the worker, reducing reach and musculoskeletal load with no line redesign.",
      "complexity": "simple"
    },

    {
      "id": "MOD-05",
      "source": "Cascini & Rissone 2004, J. Eng. Design (plastics design)",
      "language": "en",
      "domain": "materials",
      "problem": "Injection-molded plastic part needs a thin wall for cooling time but cannot warp.",
      "contradiction_pair": {
        "improving_parameter": "Productivity (#39)",
        "worsening_parameter": "Shape (#12)"
      },
      "inventive_principles": ["#3 Local quality", "#9 Preliminary anti-action", "#40 Composite materials"],
      "reasoning_chain": "1) Thinner walls cool faster but warp on demolding. 2) #3 local quality: ribs only where stiffness needed. 3) #9: pre-stress molded part. 4) #40: glass-fiber-filled composite resin.",
      "solution": "Variable-thickness ribbed design in glass-filled polymer with pre-stressing during demolding; cycle time drops 30% without warpage.",
      "complexity": "medium"
    },

    {
      "id": "MOD-06",
      "source": "Bariani, Berti, Lucchetta 2004 (DFMA + TRIZ)",
      "language": "en",
      "domain": "manufacturing",
      "problem": "Automotive subassembly with too many parts is costly to assemble; reducing parts may compromise function.",
      "contradiction_pair": {
        "improving_parameter": "Number of parts (#26 — substance amount)",
        "worsening_parameter": "Reliability (#27)"
      },
      "inventive_principles": ["#5 Merging", "#6 Universality", "#40 Composite materials"],
      "reasoning_chain": "1) Reducing parts can lose redundancy. 2) #5 merge multiple parts into one (e.g., snap-fit clip integral with bracket). 3) #6 each part takes more functions. 4) #40 composite materials enable single-piece replacement.",
      "solution": "DFMA-driven part consolidation: 23-part subassembly reduced to 8 multifunctional composite parts with equal or higher reliability.",
      "complexity": "simple"
    },

    {
      "id": "MOD-07",
      "source": "Kim, Lim, Cho 2022 IJAMT (construction layout robot)",
      "language": "en",
      "domain": "robotics/civil",
      "problem": "Robot must lay out building structure markings on uneven construction floors quickly and accurately.",
      "contradiction_pair": {
        "improving_parameter": "Accuracy of measurement (#28)",
        "worsening_parameter": "Speed (#9)"
      },
      "inventive_principles": ["#28 Mechanics substitution", "#35 Parameter changes", "#15 Dynamization"],
      "reasoning_chain": "1) Faster movement loses positional accuracy on uneven surfaces. 2) #28: replace wheel odometry with laser/lidar localization. 3) #35: variable speed based on local terrain. 4) #15: active suspension keeps marking head normal to floor.",
      "solution": "Laser-tracker-localized robot with adaptive suspension marking head: maintains <2 mm accuracy at full layout speed.",
      "complexity": "medium"
    },

    {
      "id": "MOD-08",
      "source": "Tan 2007, Int. J. Product Development (analogy-based design)",
      "language": "en",
      "domain": "biomedical",
      "problem": "Endoscope tip must steer through tortuous vessels, but added actuators make it bulky.",
      "contradiction_pair": {
        "improving_parameter": "Adaptability (#35)",
        "worsening_parameter": "Volume of moving object (#7)"
